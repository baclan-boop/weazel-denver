# Скопируйте этот файл в .env для локальной разработки (в проде эти же
# переменные задаются в настройках сервиса на Render — Environment).
# .env НЕ должен попадать в git — см. .gitignore.

# ─── Обязательно ───────────────────────────────────────────────────────
# Строка подключения к Postgres (Neon, Render Postgres и т.п.)
DATABASE_URL=postgres://user:password@host:5432/dbname

# ─── Настоятельно рекомендуется задать в проде ─────────────────────────
# Без SESSION_SECRET сервер сгенерирует случайный ключ при каждом старте —
# это работает, но разлогинивает всех пользователей при каждом редеплое.
# Любая длинная случайная строка, например: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Логин администратора, создаваемого при первом запуске. Если не задать —
# используются значения по умолчанию из кода (см. src/config.js) — для
# продового сайта их обязательно нужно переопределить своими.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Admin

# ─── Необязательно, но нужно для сохранения загруженных картинок между
# редеплоями (фоны страниц, аватарки, изображения новостей) ─────────────
# Cloudinary Dashboard → Product Environment Credentials
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Необязательно — поиск свободных слотов для объявлений (раздел
# «Реклама») через Google Таблицу, см. google-apps-script/Code.gs ───────
GOOGLE_APPS_SCRIPT_URL=

# ─── Обычно не нужно менять ────────────────────────────────────────────
PORT=3000
NODE_ENV=production
